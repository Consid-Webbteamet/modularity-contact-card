{
  "name": "consid-webbteamet/modularity-contact-card",
  "description": "Modularity contact card module",
  "type": "wordpress-plugin",
  "license": "MIT",
  "version": "dev-main",
  "authors": [
    {
      "name": "Consid Webbteamet"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "ModularityContactCard\\": "source/php/"
    }
  },
  "require": {
    "php": "^8.0"
  },
  "suggest": {
    "helsingborg-stad/municipio": "^6.0.0"
  },
  "extra": {
    "installer-name": "modularity-contact-card"
  },
  "config": {
    "optimize-autoloader": true
  }
}
